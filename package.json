{
  "name": "pianohero",
  "version": "0.1.0",
  "description": "Free open-source Synthesia clone",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@julusian/midi": "^3.6.1",
    "@pixi/react": "^7.1.2",
    "@tonejs/midi": "^2.0.28",
    "pixi.js": "^7.4.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tone": "^14.7.77"
  },
  "build": {
    "appId": "com.pianohero.app",
    "productName": "PianoHero",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
